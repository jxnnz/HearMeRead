ENVIRONMENT=development
DB_SCHEMA=dev

DATABASE_URL=URL_TO_YOUR_DATABASE
# Security
SECRET_KEY=SOME_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Field-level encryption key for student PII — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=YOUR_FERNET_ENCRYPTION_KEY

# Email
RESEND_API_KEY=ReSEND_API_KEY_HERE
EMAIL_ADDRESS=EMAIL_ADDRESS_ADDRESS_HERE
EMAIL_NAME=NAME_TO_DISPLAY_FOR_EMAILS

# App
APP_NAME=HearMeRead
DEBUG=True

# URLs
FRONTEND_URL=URL_TO_YOUR_FRONTEND
BACKEND_URL=URL_TO_YOUR_BACKEND

# Groq API (free key from https://console.groq.com/keys)
GROQ_API_KEY=YOUR_GROQ_API_KEY
